    const hasBackgroundIndex = indexes2.some(idx => idx.name === 'email_background');
    assert(hasBackgroundIndex, 'Background index not created');
    console.log('✓ Test 2 passed: Background index with options created');
    
    // Test 3: Index with sparse option
