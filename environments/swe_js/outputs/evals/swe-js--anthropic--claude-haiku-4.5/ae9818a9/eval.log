const mongoose = require('/workspace');
const { MongoMemoryServer } = require('/workspace/node_modules/mongodb-memory-server');

async function run() {
  let mongoServer;
  
  try {
    console.log('Starting MongoDB Memory Server...');
    mongoServer = await MongoMemoryServer.create();
    const mongoUri = mongoServer.getUri();
    
