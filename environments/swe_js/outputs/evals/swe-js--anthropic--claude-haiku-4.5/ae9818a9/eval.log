    const schema2 = new mongoose.Schema({ email: String });
    schema2.index({ email: 1 }, { unique: true, name: 'test_unique' });
    const Model2 = mongoose.model('TestModel2', schema2);
    await Model2.init();
    const indexes2 = await Model2.collection.getIndexes({ full: true });
    found = indexes2.find(i => i.name === 'test_unique' && i.unique);
    if (found) {
      console.log('✓ PASS: Unique index created correctly');
    } else {
      console.log('✗ FAIL: Unique index not found');
      console.log('  Indexes:', indexes2);
    }

    // Test 3: Compound index with options
    console.log('\n=== Test 3: Compound index with sparse option ===');
    const schema3 = new mongoose.Schema({ 
      first: String,
      second: String
    });
    schema3.index({ first: 1, second: 1 }, { sparse: true, name: 'compound_sparse' });
    const Model3 = mongoose.model('TestModel3', schema3);
    await Model3.init();
    const indexes3 = await Model3.collection.getIndexes({ full: true });
    found = indexes3.find(i => i.name === 'compound_sparse' && i.sparse);
    if (found) {
      console.log('✓ PASS: Compound sparse index created correctly');
    } else {
      console.log('✗ FAIL: Compound sparse index not found');
      console.log('  Indexes:', indexes3);
    }

    // Test 4: Index with collation
    console.log('\n=== Test 4: Index with collation option ===');
    const schema4 = new mongoose.Schema({ title: String });
    schema4.index({ title: 1 }, { collation: { locale: 'en' }, name: 'title_collated' });
    const Model4 = mongoose.model('TestModel4', schema4);
    await Model4.init();
    const indexes4 = await Model4.collection.getIndexes({ full: true });
    found = indexes4.find(i => i.name === 'title_collated');
    if (found && found.collation && found.collation.locale === 'en') {
      console.log('✓ PASS: Index with collation created correctly');
    } else {
      console.log('✗ FAIL: Index with collation not found or incorrect');
      console.log('  Indexes:', indexes4);
    }

    // Test 5: Index declared via schema property
    console.log('\n=== Test 5: Index via schema property ===');
    const schema5 = new mongoose.Schema({
      username: { type: String, index: true, unique: true }
    });
    const Model5 = mongoose.model('TestModel5', schema5);
    await Model5.init();
    const indexes5 = await Model5.collection.getIndexes({ full: true });
    found = indexes5.find(i => i.name === 'username_1' && i.unique);
    if (found) {
      console.log('✓ PASS: Schema property index created correctly');
    } else {
      console.log('✗ FAIL: Schema property index not found');
      console.log('  Indexes:', indexes5);
    }

    // Test 6: Multiple indexes with various options
    console.log('\n=== Test 6: Multiple indexes ===');
    const schema6 = new mongoose.Schema({
      field1: String,
      field2: String,
      field3: String
    });
    schema6.index({ field1: 1 }, { name: 'idx1' });
    schema6.index({ field2: 1 }, { name: 'idx2', sparse: true });
    schema6.index({ field1: 1, field3: 1 }, { name: 'idx3', unique: true });
    const Model6 = mongoose.model('TestModel6', schema6);
    await Model6.init();
    const indexes6 = await Model6.collection.getIndexes({ full: true });
    const idx1 = indexes6.find(i => i.name === 'idx1');
    const idx2 = indexes6.find(i => i.name === 'idx2' && i.sparse);
    const idx3 = indexes6.find(i => i.name === 'idx3' && i.unique);
    if (idx1 && idx2 && idx3) {
      console.log('✓ PASS: Multiple indexes created correctly');
    } else {
      console.log('✗ FAIL: Not all indexes found');
      console.log('  idx1:', idx1);
      console.log('  idx2:', idx2);
      console.log('  idx3:', idx3);
      console.log('  All indexes:', indexes6);
    }

    console.log('\n=== All tests completed ===');
  } catch (err) {
    console.error('Error:', err.message);
    console.error(err.stack);
  } finally {
    await mongoose.disconnect();
    if (mongoServer) {
      await mongoServer.stop();
    }
  }
}

run();
