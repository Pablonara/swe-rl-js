const mongoose = require('/workspace');
const start = require('/workspace/test/common');

async function run() {
  const db = start();

  try {
    await db.createCollection('Test').catch(() => {});
    
    // Test 1: Index with options
    const schema1 = new mongoose.Schema({ name: String });
    schema1.index({ name: 1 }, { background: true, name: 'test_background' });
    
    const Model1 = db.model('TestModel1', schema1);
    await Model1.init();
    
    const indexes1 = await Model1.collection.getIndexes({ full: true });
    console.log('Test 1 - Index with background option:');
    console.log('Indexes:', indexes1);
    
    let foundBackgroundIndex = false;
    indexes1.forEach(idx => {
      if (idx.name === 'test_background') {
        console.log('✓ Found index with correct name and options');
        foundBackgroundIndex = true;
      }
    });
    
    if (!foundBackgroundIndex) {
      console.log('✗ Background index not found');
    }

    // Test 2: Unique index with options
    const schema2 = new mongoose.Schema({ email: String });
    schema2.index({ email: 1 }, { unique: true, name: 'test_unique' });
    
    const Model2 = db.model('TestModel2', schema2);
    await Model2.init();
    
    const indexes2 = await Model2.collection.getIndexes({ full: true });
    console.log('\nTest 2 - Index with unique option:');
    console.log('Indexes:', indexes2);
    
    let foundUniqueIndex = false;
    indexes2.forEach(idx => {
      if (idx.name === 'test_unique' && idx.unique) {
        console.log('✓ Found unique index with correct name and options');
        foundUniqueIndex = true;
      }
    });
    
    if (!foundUniqueIndex) {
      console.log('✗ Unique index not found');
    }
    
    console.log('\n✓ All tests passed!');
  } catch (err) {
    console.error('Error:', err.message);
    console.error(err);
  } finally {
    await db.close();
  }
}

run();
