const mongoose = require('mongoose');
const assert = require('assert');

async function run() {
  // Use the test database URL setup used by the tests
  const dbUrl = process.env.MONGOOSE_URI || 'mongodb://127.0.0.1:27017/mongoose_test';
  
  console.log('Connecting to', dbUrl);
  await mongoose.connect(dbUrl);

  try {
    // Test 1: Index with background option
    console.log('\nTest 1: Index with background option');
    const schema1 = new mongoose.Schema({ name: String });
    schema1.index({ name: 1 }, { background: true, name: 'background_index' });
    const Model1 = mongoose.model('Test1', schema1, 'test1');
    await Model1.init();
    console.log('✓ Index with background option created successfully');

    // Test 2: Index with unique option
    console.log('\nTest 2: Index with unique option');
    const schema2 = new mongoose.Schema({ email: String });
    schema2.index({ email: 1 }, { unique: true, name: 'email_unique' });
    const Model2 = mongoose.model('Test2', schema2, 'test2');
    await Model2.init();
    console.log('✓ Index with unique option created successfully');

    // Test 3: Index with collation
    console.log('\nTest 3: Index with collation');
    const schema3 = new mongoose.Schema({ title: String });
    schema3.index({ title: 1 }, { collation: { locale: 'en', strength: 2 }, name: 'title_collation' });
    const Model3 = mongoose.model('Test3', schema3, 'test3');
    await Model3.init();
    console.log('✓ Index with collation created successfully');

    // Test 4: Multiple indexes
    console.log('\nTest 4: Multiple indexes');
    const schema4 = new mongoose.Schema({ 
      username: String,
      age: Number,
      status: String 
    });
    schema4.index({ username: 1 }, { unique: true, name: 'username_unique' });
    schema4.index({ age: 1, status: 1 }, { background: true, name: 'age_status_bg' });
    const Model4 = mongoose.model('Test4', schema4, 'test4');
    await Model4.init();
    console.log('✓ Multiple indexes created successfully');

    console.log('\n✅ All tests passed!');
  } catch (err) {
    console.error('\n❌ Test failed:', err.message);
    if (err.stack) console.error(err.stack);
    process.exit(1);
  } finally {
    await mongoose.disconnect();
  }
}

run();
EOF
