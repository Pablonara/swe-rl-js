    const Model4 = mongoose.model('Test4', schema4);
    await Model4.init();
    const indexes4 = await Model4.collection.getIndexes({ full: true });
    const hasCompoundIndex = indexes4.some(idx => idx.name === 'fullname_unique' && idx.unique);
    assert(hasCompoundIndex, 'Compound unique index not created');
    console.log('✓ Test 4 passed: Compound index with options created');
    
