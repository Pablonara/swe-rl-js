    const hasSparseIndex = indexes3.some(idx => idx.name === 'phone_sparse' && idx.sparse);
    assert(hasSparseIndex, 'Sparse index not created');
    console.log('✓ Test 3 passed: Sparse index with options created');
    
    // Test 4: Compound index with options
    const schema4 = new mongoose.Schema({ first: String, last: String });
