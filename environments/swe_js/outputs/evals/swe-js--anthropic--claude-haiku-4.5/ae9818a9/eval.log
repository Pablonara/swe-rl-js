    schema1.index({ name: 1 }, { background: true, name: 'test_background' });
    const Model1 = mongoose.model('TestModel1', schema1);
    await Model1.init();
    const indexes1 = await Model1.collection.getIndexes({ full: true });
    let found = indexes1.find(i => i.name === 'test_background');
    if (found) {
      console.log('✓ PASS: Background index created correctly');
    } else {
      console.log('✗ FAIL: Background index not found');
      console.log('  Indexes:', indexes1);
    }

    // Test 2: Unique index
